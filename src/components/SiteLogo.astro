---
import SiteMark from './SiteMark.astro';

interface Props { variant?: 'header' | 'footer'; }
const { variant = 'header' } = Astro.props;
const isFooter = variant === 'footer';
---
{isFooter ? (
  <a href="/" class="nav-logo nav-logo-footer fb-wordmark" style="margin-bottom:.75rem; display:inline-flex;">
    <SiteMark style="background:rgba(76,175,80,0.08);" />
    <span class="nav-logo-text">
      <span class="logo-word-1" style="color:rgba(255,255,255,0.9);">FITBIZ</span>
      <span class="logo-word-2" style="color:#4CAF50;">STACK</span>
    </span>
  </a>
) : (
  <a href="/" class="nav-logo nav-logo-header fb-wordmark">
    <SiteMark />
    <span class="nav-logo-text">
      <span class="logo-word-1">FITBIZ</span>
      <span class="logo-word-2">STACK</span>
    </span>
  </a>
)}
